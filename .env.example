# Mapbox (地図表示に必須)
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE

# Amplify サンドボックス起動後に amplify_outputs.json が自動生成されます
# 以下は本番デプロイ時に Amplify コンソールまたは CLI で設定するシークレット

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# APPLE_TEAM_ID=

# YouTube Data API OAuth（SNS連携画面）
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=  # サーバー側トークン交換用（将来の API Route）
